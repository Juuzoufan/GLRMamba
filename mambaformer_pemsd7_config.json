{
    "task": "traffic_state_pred",
    "model": "MambaFormer",
    "dataset": "PEMSD7",
    "saved_model": true,
    "train": true,
    "input_dim": 11,
    "output_dim": 1,
    "x_feature_dim": 3,
    "d_model": 96,
    "n_heads": 4,
    "n_layers": 3,
    "d_state": 32,
    "n_freqs": 32,
    "scales": [
        3,
        5,
        7
    ],
    "dropout": 0.2,
    "use_contrastive": false,
    "contrastive_weight": 0.0,
    "scaler": "standard",
    "load_external": true,
    "normal_external": false,
    "ext_scaler": "none",
    "add_time_in_day": true,
    "add_day_in_week": true,
    "slice_size_per_day": 288,
    "input_window": 12,
    "output_window": 12,
    "batch_size": 8,
    "seed": 3407,
    "max_epoch": 200,
    "learner": "adamw",
    "learning_rate": 0.0006,
    "weight_decay": 0.003,
    "lr_decay": true,
    "lr_scheduler": "cosinelr",
    "lr_eta_min": 1e-06,
    "lr_warmup_epoch": 15,
    "lr_warmup_init": 1e-06,
    "clip_grad_norm": true,
    "max_grad_norm": 5,
    "use_early_stop": true,
    "patience": 50,
    "set_loss": "masked_mae",
    "n_proxies": 24,
    "cache_dataset": true
}